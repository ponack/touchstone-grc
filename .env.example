# ── Core ──────────────────────────────────────────────────────────────────────
TOUCHSTONE_BASE_URL=https://touchstone.example.com
TOUCHSTONE_SECRET_KEY=replace-with-64-random-chars

# Bind/exposure for the bundled Caddy proxy (default profile)
HTTP_PORT=80
HTTPS_PORT=443

# Host-side ports for the API + UI + Grafana + Authentik. Defaults are
# deliberately offset from Crucible IAP's defaults (8080/3000/3001/9000)
# so both products can run on a single host without colliding. Override
# in this file if you have a reason to.
TOUCHSTONE_API_EXPOSE=127.0.0.1
TOUCHSTONE_API_PORT=8090
TOUCHSTONE_UI_EXPOSE=127.0.0.1
TOUCHSTONE_UI_PORT=3010

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_DB=touchstone
POSTGRES_USER=touchstone
POSTGRES_PASSWORD=replace-me

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=replace-me
MINIO_BUCKET_EVIDENCE=touchstone-evidence
MINIO_BUCKET_ARTIFACTS=touchstone-artifacts
MINIO_USE_SSL=false

# ── OIDC (any generic provider — Authentik, Okta, Google, Keycloak, …) ───────
# Leave OIDC_ISSUER_URL empty to disable OIDC. When set, all four fields are
# required. OIDC_REDIRECT_URL must point to /auth/oidc/callback on this host,
# e.g.: https://touchstone.example.com/auth/oidc/callback
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=

# ── Local auth (bootstrap admin; disable in production) ───────────────────────
LOCAL_AUTH_ENABLED=true
LOCAL_AUTH_EMAIL=admin@example.com
LOCAL_AUTH_PASSWORD=replace-me

# ── Scanner ───────────────────────────────────────────────────────────────────
# URL that ephemeral connector-scan containers use to call back to the API.
# Always the internal Docker service name, never the public URL.
SCANNER_API_URL=http://touchstone-api:8080

# ── Monitoring (Grafana admin) ────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme
TOUCHSTONE_GRAFANA_EXPOSE=127.0.0.1
TOUCHSTONE_GRAFANA_PORT=3011

# ── Authentik (optional bundled IdP, --profile authentik) ─────────────────────
AUTHENTIK_SECRET_KEY=
AUTHENTIK_BOOTSTRAP_EMAIL=
AUTHENTIK_BOOTSTRAP_PASSWORD=
AUTHENTIK_EXPOSE=127.0.0.1
AUTHENTIK_PORT=9010
