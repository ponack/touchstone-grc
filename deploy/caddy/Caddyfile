# Touchstone — bundled Caddy reverse proxy
#
# Variables read from .env at the host. The {$TOUCHSTONE_BASE_URL} placeholder
# is substituted by Caddy on startup.

{$TOUCHSTONE_BASE_URL} {
    encode zstd gzip

    # API
    handle_path /api/* {
        reverse_proxy touchstone-api:8080
    }
    handle /healthz {
        reverse_proxy touchstone-api:8080
    }

    # Grafana (sub-path)
    handle_path /grafana/* {
        reverse_proxy grafana:3000
    }

    # UI (catch-all SSR)
    handle {
        reverse_proxy touchstone-ui:3000
    }
}
