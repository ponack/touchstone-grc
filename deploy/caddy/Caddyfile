# Touchstone — bundled Caddy reverse proxy
#
# Variables read from .env at the host. The {$TOUCHSTONE_BASE_URL} placeholder
# is substituted by Caddy on startup.
#
# Routing notes:
#   - `handle`        keeps the full request path. Use this for /api/*,
#                     /auth/*, /healthz — the API expects to see them.
#   - `handle_path`   strips the matched prefix. Use only for Grafana,
#                     which is configured with GF_SERVER_SERVE_FROM_SUB_PATH.

{$TOUCHSTONE_BASE_URL} {
    encode zstd gzip

    # API — /api/v1/* + /auth/* (login, logout, OIDC) + /healthz
    handle /api/* {
        reverse_proxy touchstone-api:8080
    }
    handle /auth/* {
        reverse_proxy touchstone-api:8080
    }
    handle /healthz {
        reverse_proxy touchstone-api:8080
    }

    # Grafana (sub-path; Grafana itself rewrites its root to /grafana)
    handle_path /grafana/* {
        reverse_proxy grafana:3000
    }

    # UI (catch-all SSR)
    handle {
        reverse_proxy touchstone-ui:3000
    }
}
